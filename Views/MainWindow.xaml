<Window x:Class="Camera_Insepctor_Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Camera_Insepctor_Project"
        mc:Ignorable="d"
        Title="Camera Inspector"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="OpenCvSharp Vision Inspection"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 카메라 화면 -->
            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="0,0,12,0">
                <Grid>
                    <Image x:Name="CameraImage"
                           Stretch="Uniform"/>
                </Grid>
            </Border>

            <!-- 상태 패널 -->
            <Border Grid.Column="1"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="검사 상태"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="보정 상태"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CalibrationStatusText}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="검사 상태"
                               FontWeight="SemiBold"/>
                    
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="18"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="경고 메시지"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding WarningMessage}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,12"/>

                    <StackPanel Visibility="{Binding IsInspectionOverlaySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="측정값"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding MeasuredValueText}"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,12"/>
                    </StackPanel>

                    <TextBlock Text="화면 표시"
                               FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding DisplayModes}"
                              SelectedItem="{Binding SelectedDisplayMode}"
                              Margin="0,4,0,12"/>

                    <TextBlock Text="검사 기준"
                               FontWeight="SemiBold"
                               Margin="0,8,0,4"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
               Grid.Column="0"
               Text="홀 직경 허용 오차(mm)"
               VerticalAlignment="Center"
               Margin="0,0,8,0"/>
                        <TextBox Grid.Row="0"
             Grid.Column="1"
             Text="{Binding ToleranceMmText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBlock Text="{Binding InputValidationMessage}"
                               Foreground="Firebrick"
                               TextWrapping="Wrap"
                               Margin="0,-4,0,12"/>

                    <TextBlock Text="마지막 갱신 시간"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LastUpdatedTimeText}"
                               Margin="0,4,0,12"/>

                </StackPanel>
            </Border>
        </Grid>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,16,0,0">

            <Button Content="Load Intrinsic"
            Width="140"
            Height="40"
            Margin="0,0,12,0"
            Command="{Binding LoadIntrinsicCalibrationCommand}"/>

            <Button Content="Save Reference"
            Width="150"
            Height="40"
            Margin="0,0,12,0"
            Command="{Binding SaveReferenceCommand}"/>

            <Button Content="Update Homography"
            Width="160"
            Height="40"
            Margin="0,0,12,0"
            Click="UpdateHomographyButton_Click"/>


            <Button Content="Start"
            Width="120"
            Height="40"
            Margin="0,0,12,0"
            Click="StartButton_Click"/>

            <Button Content="Stop"
            Width="120"
            Height="40"
            Click="StopButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
